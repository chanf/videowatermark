[
  {
    "source": "*.js",
    "headers": [
      {
        "key": "Content-Type",
        "value": "application/javascript; charset=utf-8"
      }
    ]
  },
  {
    "source": "*.css",
    "headers": [
      {
        "key": "Content-Type",
        "value": "text/css; charset=utf-8"
      }
    ]
  },
  {
    "source": "*.svg",
    "headers": [
      {
        "key": "Content-Type",
        "value": "image/svg+xml; charset=utf-8"
      }
    ]
  },
  {
    "source": "/",
    "headers": [
      {
        "key": "Cache-Control",
        "value": "public, max-age=0, must-revalidate"
      }
    ]
  }
]
